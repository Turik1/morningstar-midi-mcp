# Morningstar MCP Server Configuration
# Copy to ~/.config/morningstar-mcp/setup.yaml

controller: MC8 Pro

devices:
  - name: Quad Cortex Mini
    midi_channel: 1
  - name: Strymon Timeline
    midi_channel: 2

